@model PatientDashboardViewModel
@{
    ViewData["Title"] = "Patient Dashboard";
}

<h3 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Welcome, @Model.Profile.FullName</h3>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-primary shadow-sm">
            <div class="card-body text-center">
                <h2 class="text-primary">@Model.UpcomingAppointments.Count</h2>
                <p class="text-muted mb-0">Upcoming Appointments</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success shadow-sm">
            <div class="card-body text-center">
                <h2 class="text-success">@Model.PastAppointments.Count(a => a.Status == "Completed")</h2>
                <p class="text-muted mb-0">Completed Visits</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <p class="mb-1"><strong>CPR:</strong> @Model.Profile.CPR</p>
                <p class="mb-0"><strong>Ref:</strong> @Model.Profile.PatientRefNumber</p>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-calendar-check me-2"></i>Upcoming Appointments</h5>
                <a asp-controller="Booking" asp-action="Index" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Book New
                </a>
            </div>
            <div class="card-body">
                @if (Model.UpcomingAppointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th>Doctor</th>
                                    <th>Specialization</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var apt in Model.UpcomingAppointments)
                                {
                                    <tr>
                                        <td>@apt.AppointmentDate.ToString("dd MMM yyyy")</td>
                                        <td>@apt.StartTime - @apt.EndTime</td>
                                        <td>@apt.Doctor</td>
                                        <td>@apt.Specialization</td>
                                        <td><partial name="_StatusBadge" model="@apt.Status" /></td>
                                        <td>
                                            @if (apt.Status == "Requested" || apt.Status == "Confirmed")
                                            {
                                                <form asp-action="CancelAppointment" asp-route-id="@apt.Id" method="post"
                                                      onsubmit="return confirm('Are you sure you want to cancel this appointment?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-x-circle"></i> Cancel
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-calendar-x display-4"></i>
                        <p class="mt-2">No upcoming appointments.</p>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-primary">Book an Appointment</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Past Appointments</h5>
    </div>
    <div class="card-body">
        @if (Model.PastAppointments.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Doctor</th>
                            <th>Specialization</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var apt in Model.PastAppointments)
                        {
                            <tr>
                                <td>@apt.AppointmentDate.ToString("dd MMM yyyy")</td>
                                <td>@apt.StartTime - @apt.EndTime</td>
                                <td>@apt.Doctor</td>
                                <td>@apt.Specialization</td>
                                <td><partial name="_StatusBadge" model="@apt.Status" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No past appointments.</p>
        }
    </div>
</div>
