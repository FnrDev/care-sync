@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold text-primary">
        <i class="bi bi-heart-pulse me-2"></i>CareSync
    </h1>
    <p class="lead text-muted mt-3">Your trusted healthcare appointment management system</p>

    <div class="row justify-content-center mt-5 g-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-search display-4 text-primary"></i>
                    <h5 class="mt-3">Track Appointment</h5>
                    <p class="text-muted">Look up your appointment status using your CPR and reference number.</p>
                    <a asp-controller="Tracking" asp-action="Index" class="btn btn-outline-primary">
                        Track Now
                    </a>
                </div>
            </div>
        </div>

        @if (ViewBag.IsAuthenticated != true)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-box-arrow-in-right display-4 text-success"></i>
                        <h5 class="mt-3">Patient / Staff Login</h5>
                        <p class="text-muted">Sign in to manage appointments, view records, or manage the queue.</p>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-success">
                            Sign In
                        </a>
                    </div>
                </div>
            </div>
        }
        else if (ViewBag.UserRole == "Patient")
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-calendar-plus display-4 text-success"></i>
                        <h5 class="mt-3">Book Appointment</h5>
                        <p class="text-muted">Schedule an appointment with your preferred doctor.</p>
                        <a asp-controller="Booking" asp-action="Index" class="btn btn-outline-success">
                            Book Now
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-journal-medical display-4 text-info"></i>
                        <h5 class="mt-3">Medical Records</h5>
                        <p class="text-muted">View your visit history, diagnoses, and prescriptions.</p>
                        <a asp-controller="Patient" asp-action="MedicalRecords" class="btn btn-outline-info">
                            View Records
                        </a>
                    </div>
                </div>
            </div>
        }
        else if (ViewBag.UserRole == "Receptionist")
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-speedometer2 display-4 text-success"></i>
                        <h5 class="mt-3">Manage Queue</h5>
                        <p class="text-muted">View today's appointments and manage check-ins.</p>
                        <a asp-controller="Receptionist" asp-action="Dashboard" class="btn btn-outline-success">
                            Go to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
